{
  "name": "astro-payload-live-preview-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter astro-payload-live-preview build",
    "clean": "pnpm --filter astro-payload-live-preview clean",
    "dev:payload": "pnpm --filter payload-app dev",
    "dev:website": "pnpm --filter astro-website dev",
    "release": "pnpm build && pnpm --filter astro-payload-live-preview publish"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "@swc/core", "esbuild", "sharp"]
  }
}
